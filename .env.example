# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# Google Gemini
GEMINI_API_KEY=AIza...

# Base URL para la Python function (en local, http://localhost:3000)
# En producción Vercel lo resuelve solo si está en el mismo deployment
PYTHON_FUNCTION_BASE_URL=

# Opcional: Sentry para errores en producción
SENTRY_DSN=

# Opcional: Tipo de cambio API (si no usás uno, hardcodear en lib/fx.ts)
FX_API_KEY=
